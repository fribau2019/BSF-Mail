Unit BSFDown;

{$I E:\SOURCE~1\PASCAL\NETMAIL\LANGAGE.DIR}

Interface

 Procedure Download(Auto       : Boolean;       {Procedure Automatique ?}
                    Personnel  : Boolean;       {Procedure Mode Personel ?}
                    Prescan    : Boolean);      {Procedure Prescan ?}


Implementation

Uses Crt,
     Dos,
     BSFCRC32,
     BSFCOMM,
     BSFBulls,
     BSFLog,
     BSFConst,
     BSFUtils,
     BSFSwap;


CONST TempDir  : String[8] = '0000000';
      OldBBSID : String[8] = '0000000';

TYPE
  Bsingle        = Array [0..3] Of Byte;
(* SFMSG[x].PTR *)
  MessagePtr    = Record
                          MDate            : String[17];
                          FromWho,
                          ToWho,
                          OrgTo            : String[30];
                          Subject          : String[40];
                          NetMail,
                          MsgSent,
                          Available,
                          ThreadMsg,
                          ThreadStart,
                          Private,Deleted,
                          Received         : Boolean;
                          Where,
                          NumberofRecords  : Word;
                          Conference       : Integer;
                          MsgNumber,
                          OrgMsgNumber     : LongInt;
                          QWK_ID           : String[8];
                          QWK_Delete_Org   : Boolean;
                          DupChkCRC        : LongInt;
                          FireNetReserved  : Array[0..26] Of Char;
                          NetRoute         : String[16];
                          Extra            : Array[0..23] Of Byte;
                  End;
(* MESSAGE.DAT *)
  MessageDAT    = record
                   msgstatus     : char;
                   msgnum        : String[7];
                   date          : String[8];
                   time          : String[5];
                   msgto         : String[25];
                   msgfrom       : String[25];
                   msgsubj       : String[25];
                   msgpswd       : String[12];
                   refnum        : String[8];
                   numblks       : String[6];
                   kill          : Char;
                   confnum       : word;
                   blank         : word;
                   ntwktag       : String[3];
 End;

PrivSecArray  = Array[1..5] Of Integer;

MsgSystem     = Record
                  MSec           : Integer;
                  NetMailConf    : Boolean;
                  MDesc          : String[18];
                  MSub           : String[21];
                  MEqual,
                  PublicMsgConf,
                  AllowDelete,
                  PackUnReceived : Boolean;
                  DaysOld        : Word;
                  DelOldThdMsg   : Boolean;
                  NoOfLines      : Word;
                  OneExtra       : Boolean;
                  PrivSec        : PrivSecArray;
                  MsgEntrySec    : Word;
                  Extra          : Array[1..44] Of Byte;
                  AllowNetRoute,
                  MarkAsSent     : Boolean;
                  NetIDName      : String[15];
                End;

(* SFMSG[x].IDX *)
  MessageIdx    = Record
                   FromWhoCRC,
                   ToWhoCRC,
                   MsgNumber,
                   OrgMsgNumber   : LongInt;
  End;
(* SFMSG[x].DAT *)
  MessageBody   = Record
                            MsgData : String[127];
                           End;

  MessageIn   = Array[1..250] of ^String;
  MessageOut  = Array[1..250] of ^String;



VAR
    F          : Text;
    DownGood   : Boolean;
    TotalCFR   : Word;
    Perso,
    NDXF       : Text ;
    MsgS       : File Of MsgSystem;
    Msg        : MsgSystem;
    IDX        : File Of MessageIDX;
    PointIDX   : MessageIDX;
    PTR        : File Of MessagePTR;
    PointPTR   : MessagePTR;
    DataM      : File Of MessageBody;
    Data       : MessageBody;
    Mail       : MessageDAT;
    Message    : File;
    FPres      : File Of Byte;
    C          : Char;
    PosMail,
    TotalYour,
    NombreMail,
    TotalMail  : LongInt;
    ToYou,
    Conf       : Word;
    Posi,
    Lower,
    Higher,
    LastRead   : LongInt;
    J          : LongInt;
    Position   : Integer;
    Choix      : Byte;
    Buf        : Array[1..128] Of Char;
    BSin       : Bsingle;
    TextIn     : MessageIn;
    LastIn,
    LastOut,
    Lines      : Byte;
    Commande   : String;
    SavePoint  : Array[0..Register] Of LongInt;
    PERSS      : Byte;
    Fichier    : File Of Byte;
    Ftime      : DateTime;
    Stop       : Boolean;
{---------------------------------------------------------------------------}
Function Moving(Auto : Boolean; Prescan : Boolean) : Boolean;
VAR
    Fichier1,
    Fichier2   : File;
    Buffe      : Array[1..2048] of Char;
    NumRead,
    NumWritten,
    Max        : Word;
    Extension  : String[3];
    Bon        : Boolean;
    D          : Char;

Begin;

 Moving := False;

 Writeln;

If Not Prescan Then
{$IFDEF ENGLISH}
 RmWriteln('ţ Moving '+Config.BBSID+'.QWK To '+Config.LocalQWK)
{$ELSE}
 RmWriteln('ţ Transfert De '+Config.BBSID+'.QWK Vers '+Config.LocalQWK)
{$ENDIF}
Else
{$IFDEF ENGLISH}
 RmWriteln('ţ Moving '+OldBBSID+'.QWK To '+Config.LocalQWK+Config.BBSID+'.QWK');
{$ELSE}
 RmWriteln('ţ Transfert De '+OldBBSID+'.QWK Vers '+Config.LocalQWK+Config.BBSID+'.QWK');
{$ENDIF}

 If Not Prescan Then
 If FileExists(Config.LocalQWK+Config.BBSID+'.QWK') = True Then
  Begin
   RmWriteln('');
   RmWrite('ţ Fichier '+Config.BBSID+'.QWK Existant! <Q>uit, <C>opy, <A>ppend : ');
   If Auto = False Then
    Repeat
     D := Upcase(ReadKey);
    Until D in ['Q', 'C', 'A', #13]
    Else D := 'A';
   If D = #13 Then D := 'A';
   RmWriteln(D);
  End
 Else D := 'C'
 Else D := 'C';

  Case D Of
   'Q' : Begin;
          Close(Fichier1);
          Moving := False;
         End;

   'C' : Begin;

          FCopy(Tempdir+'\'+Config.BBSID+'.QWK',Config.LocalQWK+Config.BBSID+'.QWK');

          RmWriteln('');
         If Not Prescan Then
         {$IFDEF ENGLISH}
          RmWriteln('ţ Successfull Transfering '+Config.BBSID+'.QWK !')
         {$ELSE}
          RmWriteln('ţ Transfert '+Config.BBSID+'.QWK R‚ussi !')
         {$ENDIF}
         Else
         {$IFDEF ENGLISH}
          RmWriteln('ţ Successfull Transfering '+OldBBSID+'.QWK !');
         {$ELSE}
          RmWriteln('ţ Transfert '+OLDBBSID+'.QWK R‚ussi !');
         {$ENDIF}
          SuccessTransfert;
          Moving := True;
          User.LastQWKDate := Date(0);
          User.LastQWKTime := Time;
          User.NbMessDown := User.NbMessDown + ToTalMail;
          Inc(User.NbDownPacket);
         End;

   'A' : Begin;
          Extension := 'QWK';
          Bon := False;
          Max := 0;
          Repeat
           If FileExists(Config.LocalQWK+Config.BBSID+'.'+Extension) = True
           Then Begin;
                 Extension := 'QW'+IntToStr(Max);
                 Bon       := False;
                End
           Else Bon := True;
           Inc(Max);
          Until ( (Bon = True) Or (Max > 10) );


         If Bon = False Then Begin;
                              Close(Fichier1);
                              RmWriteln('');
                             {$IFDEF ENGLISH}
                              RmWriteln('ţ Too Much QWK !!!');
                             {$ELSE}
                              RmWriteln('ţ Trop De QWK !!!');
                             {$ENDIF}
                              TooMuchQWK;
                              Delay(2000);
                              Moving := False;
                             End
         Else
          Begin;
           FCopy(Tempdir+'\'+Config.BBSID+'.QWK',Config.LocalQWK+Config.BBSID+'.'+Extension);

           RmWriteln('');
          If Not Prescan Then
          {$IFDEF ENGLISH}
           RmWriteln('ţ Successfull Transfering '+Config.BBSID+'.'+Extension+' !')
          {$ELSE}
           RmWriteln('ţ Transfert '+Config.BBSID+'.'+Extension+' R‚ussi !')
          {$ENDIF}
          Else
          {$IFDEF ENGLISH}
           RmWriteln('ţ Successfull Transfering '+OldBBSID+'.'+Extension+' !');
          {$ELSE}
           RmWriteln('ţ Transfert '+OLDBBSID+'.'+Extension+' R‚ussi !');
          {$ENDIF}
           SuccessTransfert;
           Moving := True;
           User.LastQWKDate := Date(0);
           User.LastQWKTime := Time;
           User.NbMessDown := User.NbMessDown + ToTalMail;
           Inc(User.NbDownPacket);
          End;
        End;
    End;
End;

{-------------------------------------------------------------------------}
Procedure realtomsb (preal : real; var b : Bsingle);
var
         r : array [0 .. 5] of byte absolute preal;
Begin
         b [3] := r [0];
         move (r [3], b [0], 3);
End;
{---------------------------------------------------------------------------}
Function Flags(Numero : Byte) : String;
Begin;
 If Numero < 0   Then Flags := ' NONE';
 If Numero = 0   Then Flags := ' NONE';
 If Numero = 1   Then Flags := ' ALL ';
 If Numero = 2   Then Flags := 'P/ALL';
 If Numero = 3   Then Flags := 'PERSO';
 If Numero = 101 Then Flags := ' NET ';
 If Numero > 101 Then Flags := ' NONE';
End;
{---------------------------------------------------------------------------}
Function SFMSG(Rec : Integer) : String;
Begin;
 If Rec < 9  Then SFMSG := 'SFMSG0'+IntToStr(Rec+1)
  Else SFMSG := 'SFMSG'+IntToStr(Rec+1);
End;
{---------------------------------------------------------------------------}
Function LMR(Mode : Byte; Rec, Chiffre : Integer) : LongInt;
TYPE
(* SFMSG[X].LMR *)
LastMessage   = Record
                  LMsgRed : LongInt;
                End;

VAR
    LM         : File Of LastMessage;
    L          : LastMessage;

Begin;
  Assign(LM, Config.MsgDir+SFMSG(Rec)+'.LMR');
  {$I-} Reset(LM); {$I+}
  If Ioresult = 0 Then
   Begin;
    If FileSize(LM) > 0 Then
     If Mode = 0 Then {Lecture}
      Begin;
       Seek(LM, USer.SFNumero);
       Read(LM, L);
       LMR := L.LMSgRed;
      End;
     If Mode = 1 Then {Ecriture}
      Begin;
       Seek(LM, USer.SFNumero);
       Read(LM, L);
       L.LMSgRed := Chiffre;
       Seek(LM, USer.SFNumero);
       Write(LM, L);
      End;
    Close(LM);
   End
  Else
   Begin;
    LMR := 0;
   End;
End;
{---------------------------------------------------------------------------}
Procedure EffaceSecour;
Var FichierAEffacer,
    LM,
    DataM,
    IDX,
    NDXF,
    PTR,
    MsgS,
    Message,
    Perso      : File;
    Texte      : Text;
    DirInfo    : SearchRec;

Begin;

  {$I-}
  Close(LM);
  Close(DataM);
  Close(IDX);
  Close(NdXf);
  Close(PTR);
  Close(Msgs);
  Close(Message);
  Close(Perso);
  Close(F);
  Close(Fichier);
  {$I+}

  If IoResult <> 0 Then;


  {$I-} MkDir(Tempdir); {$I+}
  If Ioresult = 0 Then Begin;
                        RmDir(Tempdir);
                        Exit;
                       End
  Else
  Begin;

  Repeat
   FindFirst(Tempdir+'\*.*', Archive, DirInfo);
  While DosError = 0 Do Begin;
                        Assign(FichierAEffacer, TempDir+'\'+DirInfo.Name);
                        {$I-} Close(FichierAEffacer); {$I+}
                        If Ioresult <> 0 Then;
                        Erase(FichierAEffacer);
                        FindNext(DirInfo);
                        End;
  Until DosError <> 0;
  RmDir(TempDir);
       End;
End;
{---------------------------------------------------------------------------}
Procedure UpdatedPoint;
TYPE
(* SFMSG[X].LMR *)
LastMessage   = Record
                  LMsgRed : LongInt;
                End;
Var  I          : Integer;
     MsgS       : File Of MsgSystem;
     LM         : File Of LastMessage;
     LMR        : LastMessage;

Begin;

 Assign(MsgS, Config.SfDir+'SFMCONF.DAT');
 Reset(MsgS);

 For I := 0 To FileSize(MsgS) Do
  If User.Conf.Attribut[I] In [1,2,3,4,101] Then If SavePoint[I] > 0  Then
  Begin;
   Assign(LM, Config.MsgDir+SFMSG(I)+'.LMR');
   {$I-} Reset(LM); {$I+}
   If FileSize(LM) > 0 Then
    Begin;
     LMR.LMSgRed := SavePoint[I];
     Seek(LM, User.SFNumero);
     Write(LM, LMR);
    End;
   Close(LM);
  End;
 Close(MsgS);
End;
{---------------------------------------------------------------------------}
Function NomIDX(Rec : Integer) : String;
Begin;
 If Rec < 9  Then                  NomIDX := '00'+IntToStr(Rec+1);
 If Rec >=9  Then If Rec < 99 Then NomIDX := '0' +IntToStr(Rec+1);
 If Rec >=99 Then                  NomIDX :=      IntToStr(Rec+1);
End;
{---------------------------------------------------------------------------}
Function Compres(Point : Byte) : String;
TYPE
  ConfigurationCompresssion = RECORD
                        Lettre      : String[01];
                        Name        : String[03];
                        DeCompress  : String[60];
                        compress    : String[60];
  End;

VAR Comp        : ConfigurationCompresssion;
    Compress    : File Of  ConfigurationCompresssion;

Begin;
 Assign(Compress, Config.BsfMailDir+'BSFCOMP.DAT');
 Reset(Compress);
 Seek(Compress, User.Compression);
 Read(Compress, Comp);
 Close(Compress);

 If ( (Comp.Lettre >= 'A') And (Comp.Lettre <= 'Z')) Then
                                                     Else Comp.Lettre := '';

 Compres := '';

 If Point = 0 Then Compres := IntToStr(FileSize(Compress)-1);
 If Point = 1 Then Compres := Comp.Lettre;
 If Point = 2 Then Compres := Comp.Name;
 If Point = 3 Then Compres := Comp.DeCompress;
 If Point = 4 Then Compres := Comp.Compress;

End;
{---------------------------------------------------------------------------}
Function Protoc(Point : Byte) : String;
TYPE
  ConfigurationProtocoles = RECORD
                        Lettre      : String[01];
                        Name        : String[20];
                        Send        : String[60];
                        Receive     : String[60];
  End;
VAR
    Proto      : ConfigurationProtocoles;
    Protocol   : File Of ConfigurationProtocoles;

Begin;
 Assign(Protocol, Config.BsfMailDir+'BSFPROTO.DAT');
 Reset(Protocol);
 Seek(Protocol, User.Protocol);
 Read(Protocol, Proto);
 Close(Protocol);


 If ( (Proto.Lettre >= 'A') And (Proto.Lettre <= 'Z')) Then
                                                       Else Proto.Lettre := '';

 Protoc := '';

 If Point = 1 Then Protoc := Proto.Lettre;
 If Point = 2 Then Protoc := Proto.Name;
 If Point = 3 Then Protoc := Proto.Receive;
 If Point = 4 Then Protoc := Proto.Send;

End;
{---------------------------------------------------------------------------}
Procedure CONTROLDAT(TotalMail : Integer; Prescan : Boolean);

VAR    CtrlDAT    : Text;
       MsgS       : File Of MsgSystem;
       Msg        : MsgSystem;
       Conferen   : Text;
       I          : Integer;
       SfNet      : String[10];

Begin;

  Assign(MsgS, Config.SfDir+'SFMCONF.DAT');
  Reset(MsgS);

  Assign(CtrlDAT, TempDir+'\CONTROL.DAT');
  {$I-} Reset(CtrlDAT); {$I+}
  If Ioresult <> 0 Then;
  ReWrite(CtrlDAT);
  Writeln(CtrlDAT, config.BBSName);
  Writeln(CtrlDAT, Config.BBSCITY);
  Writeln(CtrlDAT, Config.BBSPHONE);
  Writeln(CtrlDAT, Config.SysOpName +' ,Sysop');
  If Not Prescan Then Writeln(CtrlDAT, '0000,'+ Config.BBSID)
                 Else Writeln(CtrlDAT, '0000,'+ OldBBSID);
  Writeln(CtrlDAT, Date(1)+','+Time);
  Writeln(CtrlDAT, UserName);
  Writeln(CtrlDAT);
  Writeln(CtrlDAT, '0');
  Writeln(CtrlDAT, IntToStr(ToTalMail));
 If User.SmallControl = True Then Writeln(CtrlDAT, TotalCfR)
                             Else Writeln(CtrlDAT, FileSize(MsgS)-1);

 Assign(Conferen, Config.BsfMailDir+'BSFCONF.DAT');
 Reset(Conferen);
 For I := 0 To FileSize(MSGS)-1 Do
  Begin
   ReadLn(Conferen, SfNet);
   If User.SmallControl = True  Then
   If User.Conf.Attribut[I] > 0 Then
    Begin;
     Writeln(CtrlDAT, I+1);
     Writeln(CtrlDAT, SfNet);
    End;
   If User.SmallControl = False Then
    Begin;
     Writeln(CtrlDAT, I+1);
     Seek(Msgs, I);
     Read(Msgs, Msg);
     If SecLevel >= Msg.MSec Then Writeln(CtrlDAT, SFNet)
                             Else Writeln(CtrlDat, '');
    End;
   End;
 Close(Conferen);

 Writeln(CtrlDAT, 'WELCOME');
 Writeln(CtrlDAT, 'NEWS');
 Writeln(CtrlDAT, 'GOODBYE');
 If User.SendUserinf = True Then
  Begin;
   Writeln(CtrlDAT, '0');
   Writeln(CtrlDAT, '11');
   Writeln(CtrlDAT, MAJ(UserName));
   Writeln(CtrlDAT, UserFirstName);
   Writeln(CtrlDAT, CallingFrom);
   Writeln(CtrlDAT, PhoneNumber);
   Writeln(CtrlDAT, PhoneNumber);
   Writeln(CtrlDAT, SecLevel);
   Writeln(CtrlDAT, '00-00-1980');
   Writeln(CtrlDAT, User.LastQWKDate);
   Writeln(CtrlDAT, User.LastQWKTime);
   Writeln(CtrlDAT, User.NbConnection);
   Writeln(CtrlDAT, '0');
  End;
 Close(CtrlDAT);
 Close(MsgS);

End;
{---------------------------------------------------------------------------}
Procedure DOORID;
VAR    CtrlDAT    : Text;
Begin;
 Assign(CtrlDAT, TempDir+'\DOOR.ID');
 {$I-} Reset(CtrlDAT); {$I+}
 If Ioresult <> 0 Then;
 ReWrite(CtrlDAT);
 Writeln(CtrlDAT, 'DOOR=BSFMail');
 Writeln(CtrlDAT, 'VERSION='+Version);
 Writeln(CtrlDAT, 'SYSTEM=SPITFIRE');
 Writeln(CtrlDAT, 'CONTROLNAME=BSFMAIL');
 Writeln(CtrlDAT, 'CONTROLTYPE=ADD');
 Writeln(CtrlDAT, 'CONTROLTYPE=DROP');
 Writeln(CtrlDAT, 'CONTROLTYPE=RESET');
{Writeln(CtrlDAT, 'CONTROLTYPE=REQUEST');}
 Close(CtrlDAT);
End;
{---------------------------------------------------------------------------}
Procedure NetFlag(SFdir : String);
 Var Nombre : Integer;
     I : Integer;
     MsgS : File Of MsgSystem;
     Flag       : Text;
Begin;
 Assign(MsgS, SfDir+'SFMCONF.DAT');
 Reset(MsgS);
 Nombre := 0;
 For I := 0 To Filesize(MsgS) Do If User.Conf.Attribut[I] >= 100 Then Inc(Nombre);
 If Nombre > 0 Then
 If Not FileExists(TempDir+'\NETFLAGS.DAT') Then
                  Begin;
                    Assign( Flag, TempDir+'\NETFLAGS.DAT');
                    {$I-} Reset(Flag); {$I+}
                    If Ioresult <>0 Then;
                    ReWrite(FLAG);
                    Write(FLAG, Chr(0));
                    For I := 1 To FileSize(MsgS) DO If User.Conf.Attribut[I-1] >= 100 Then Write(FLAG, Chr(255))
                                                    Else Write(FLAG, Chr(0));
                    Close(FLAG);
                    End;
 Close(MsgS);
End;
{---------------------------------------------------------------------------}
Procedure BBSIDPNT(Prescan : Boolean);
TYPE
(* BBSID.PNT *)
  Pointeurs = Record
               Position : LongInt;
              End;
(* SFMSG[X].LMR *)
LastMessage   = Record
                  LMsgRed : LongInt;
                End;


VAR PNT        : File Of Pointeurs;
    Point      : Pointeurs;
    I          : Integer;
    LM         : File Of LastMessage;
    LMR        : LastMessage;

Begin;
(* Creation Du BBSID.PNT *)
  If Prescan Then If FileExists(TempDir+'\'+OLDBBSID+'.PNT') Then Exit;

  If Prescan Then Assign(PNT, TempDir+'\'+OLDBBSID+'.PNT')
             Else Assign(PNT, TempDir+'\'+Config.BBSID+'.PNT');
  {$I-} Reset(PNT); {$I+}
  If Ioresult <> 0 Then;
  ReWrite(PNT);
  For I := 0 To Register Do Begin;
(* Ouverture/Fermeture du fichier SFMSG[x].LMR *)
                         If User.Conf.Attribut[I] > 0 Then
                         If FileExists(Config.MsgDir+SFMSG(I)+'.LMR') = True Then
                          Begin;
                           Assign(LM, Config.MsgDir+SFMSG(I)+'.LMR');
                           Reset(LM);
                           Seek(LM, User.SFNumero);
                           Read(LM, LMR);
                           Close(LM);
                          End
                          Else LMR.LmSgRed := 0
                          Else LMR.LmSgRed := 0;
                          Point.Position := LMR.LmSgRed;
                          Write(PNT, Point);
                        End;
  Close(PNT);
End;
{---------------------------------------------------------------------------}
Procedure Entete(Rec : Integer; TotalMail : LongInt; Netmail : Boolean);
Var II : Integer;
Begin;
        (* Public / Not Read *)
             If PointPtr.Private = False Then If PointPTR.Received = False Then Mail.MsgStatus := ' ';
        (* Public / Read *)
             If PointPtr.Private = False Then If PointPTR.Received = True  Then Mail.MsgStatus := '-';
        (* Private *)
             If PointPtr.Private = True Then Mail.MsgStatus := '+';
   Buf[1] := Mail.MsgStatus;
        (* Message Number *)
         Mail.MsgNum := IntToStr(PointPTR.MsgNumber)+ '                            ';
   For II := 2 To 8 Do Buf[II] := Mail.MsgNum[II-1];
        (* Date *)
         Mail.Date   := Copy(PointPTR.MDate, 1,8)+ '                            ';
   For II := 9 To 16 Do Buf[II] := Mail.Date[II-8];
        (* Time *)
         Mail.Time   := Copy(PointPTR.MDate, 10,15)+ '                            ';
   For II := 17 To 21 Do Buf[II] := Mail.Time[II-16];
        (* Message TO *)
         Mail.MsgTo  := MAJ(PointPTR.ToWho+ '                            ');
   For II := 22 To 46 Do Buf[II] := Mail.MsgTo[II-21];
        (* Message From *)
         Mail.MsgFrom:= MAJ(PointPTR.FromWho+ '                            ');
   For II := 47 To 71 Do Buf[II] := Mail.MsgFrom[II-46];
        (* Message subject *)
         Mail.MsgSubj:= PointPTR.Subject + '                            ';
   For II := 72 To 96 Do Buf[II] := Mail.MsgSubj[II-71];
        (* Message Password *)
         Mail.MsgPswd:= '             ';
   For II := 97 To 108 Do Buf[II] := Mail.MsgPsWd[II-96];
        (* Message Reference *)
         Mail.RefNum := IntToStr(PointPTR.OrgMsgNumber)+ '                            ';
   For II := 109 To 116 Do Buf[II] := Mail.RefNum[II-108];
        (* Number Of Block *)
         Mail.NumBlks:= IntToStr(PointPTR.NumberOfRecords+1)+ '                            ';
   For II := 117 To 122 Do Buf[II] := Mail.NumBlKs[II-116];
        (* Message Active/Alive *)
         Mail.Kill   := Chr(225);
   Buf[123] := Mail.Kill;
        (* # Conference Du Message *)
         Mail.ConfNum:= PointPTR.Conference;
   Buf[124] := Chr(Mail.ConfNum);
        (* Blank ! *)
         Mail.Blank  := 20;
   Buf[125] := Chr(0);
        (* Nb Mail *)
   Buf[127] := Chr(HexToInt(Copy(Nubase(ToTalMail+1,16,4), 1,2)));
   Buf[126] := Chr(HexToInt(Copy(Nubase(TotalMail+1,16,4), 3,2)));
        (* NtwkTag *)
   If Netmail = True Then Buf[128] := '*' Else Buf[128] := ' ';

End;
{---------------------------------------------------------------------------}
{---------------------------------------------------------------------------}
{---------------------------------------------------------------------------}
Procedure EcritureMessage(Conf : Integer);
VAR posit : LongInt;
{---------------------------------------------------------------------------}
Begin;
   {Ecriture Entete}
        BlockWrite(Message, Buf, 1);
        RealToMsb(FileSize(Message), Bsin);
        Write(NDXF, Chr(Bsin[0])+Chr(Bsin[1])+Chr(Bsin[2])+Chr(Bsin[3])+Chr(Conf+1));
        If PointPTR.ToWho = UserName Then
        Write(PERSO, Chr(Bsin[0])+Chr(Bsin[1])+Chr(Bsin[2])+Chr(Bsin[3])+Chr(Conf+1));
        Posit := PointPTR.Where;
        Lines := 0;
        FillChar( TextIn,  Sizeof(TextIn), 0 );
        Repeat
        Seek(DataM, Posit);
        Read(DataM, Data);
        Inc( Lines );
        GetMem( TextIn[Lines], 129);
        TextIn[Lines]^ := Data.MsgData;
        INC(Posit);
        Until ( (Posit >= PointPTR.Where+PointPTR.NumberOfRecords) Or (Posit >= FileSize(DataM)) );
        LastIn := Lines-1;

    For Lines := 1 To Lastin+1 Do
     Begin;

     Repeat
      If Length(TextIn[Lines]^) < 128 Then
       If Lines < LastIn+1 Then
        Begin;
         If Length(TextIn[Lines+1]^) > 0 Then
          Begin;
           TextIn[Lines]^ := TextIn[Lines]^ + TextIn[Lines+1]^[1];
           Delete(TextIn[Lines+1]^,1,1);
          End
         Else
          Begin;
           TextIn[Lines]^ := TextIn[Lines]^ + TextIn[Lines+2]^[1];
           Delete(TextIn[Lines+2]^,1,1);
          End
        End;
     Until ( (Length(TextIn[Lines]^) = 128) Or (Lines >= LastIn) );

     If Lines < LastIn+1 Then
     If Length(TextIn[Lines]^) < 128 Then
     If Length(TextIn[Lines+1]^) > 0 then
      Repeat
       TextIn[Lines]^ := TextIn[Lines]^ + TextIn[Lines+1]^[1];
       Delete(TextIn[Lines+1]^,1,1);
      Until ( (Length(TextIn[Lines]^) = 128) Or (Length(TextIn[Lines+1]^) = 0));

 {Remplace Les Tetes Par Des Pi}
     If Length(TextIn[Lines]^) > 0 then
     While Pos(Chr(01), TextIn[Lines]^) <> 0 Do
      For J := 1 To 128 Do
        If TextIn[Lines]^[J] = Chr($01)
         Then TextIn[Lines]^[J] := 'ă';

     If Length(TextIn[Lines]^) < 128 Then
      TextIn[Lines]^ := TextIn[Lines]^
     +Copy('                                                                 '
     +'                                                                 ',1,128-Length(TextIn[Lines]^));

     Fillchar(Buf, SizeOf(Buf), ' ');
     For J := 1 To 128 Do Buf[J] := TextIn[Lines]^[J];
      BlockWrite(Message, Buf, 1);

     End;

    For J := LastIn+1 downto 1 do
     FreeMem( TextIn[J], 1+Length(TextIn[J]^) );

End;
{---------------------------------------------------------------------------}
Function LectureIDX : LongInt;
Begin;
 Assign(IDX, Config.MSGDir+SFMSG(Conf)+'.IDX');
 {$I-} Reset(IDX); {$I+}
 If IoResult = 0 Then
 If FileSize(IDX) > 0 Then Begin;
                             Seek(IDX, FileSize(IDX)-1);
                             Read(IDX, PointIDX);
                             LectureIDX := PointIDX.MsgNumber;
                             Close(IDX);
                            End
                       Else Begin;
                             LectureIDX := 0;
                             Close(IDX);
                            End
                       Else  LectureIDX := 0;

End;
{---------------------------------------------------------------------------}
{---------------------------------------------------------------------------}
Procedure Download(Auto       : Boolean;
                   Personnel  : Boolean;
                   Prescan    : Boolean);

Var Nombre : Integer;
    I      : Byte;
    NetId  : String[30];

Begin;

(* Variable a 0 *)
  Stop       := False;
  TotalYour  := 0;
  NombreMail := 0;
  ToTalMail  := 0;
  ToYou      := 0;
  Conf       := 0;



(* Si User En Statut Netmail Et Perso *)
  If ( (User.NetStatus = True) And (Personnel = True) ) Then
   Begin;
    RmWriteln('');
   {$IFDEF ENGLISH}
    RmWriteln('ţţţ Option Not Available For Netmail Status !!! ţţţ');
   {$ELSE}
    RmWriteln('ţţţ Option Non Disponible En Statut Netmail !!! ţţţ');
   {$ENDIF}
    RmWriteln('');
    Delay(1200);
    Exit;
   End;

(* Calcule Le Nombre De Conference Active *)
  TotalCfR := 0;
  For J := 0 To Register Do If User.Conf.Attribut[J] In [1,2,3,4,101] Then Inc(TotalCfR);
  If TotalCfR = 0 Then
   Begin;
    RmWriteln('');
   {$IFDEF ENGLISH}
    RmWriteln('ţţţ Please Select Conference First ! ţţţ');
   {$ELSE}
    RmWriteln('ţţţ Veuillez S‚lectionner Les Conf‚rences En Premier ! ţţţ');
   {$ENDIF}
    RmWriteln('');
    Delay(2000);
    Exit;
   End;

 Dec(TotalCfR);


(* Affiche Ecran De Depart *)
RmClrSCr;

(* Creation Du Repertoire Temporaire *)
  TempDir := IntToStr(Abs(CRC(UserName)));
   {$I-} MkDir(Tempdir); {$I+}
   If Ioresult <> 0 Then ;

 OldBBSID := Config.BBSID;

 If Not Prescan Then
 If Not Auto Then
 If FileExists(Config.PrescanDir+TempDir+'.QWK') Then
  Begin;
   RmWriteln('ţ DOWNLOAD Prescan QWK');
   RmWriteln('');

  {Lecture De La Taille Du Fichier}
   Assign(FPres,Config.PrescanDir+TempDir+'.QWK');
   Reset(FPres);
   RmWriteln('ţ Taille : '+IntToStr(FileSize(FPres))+' octects.');
   Close(FPres);
   RmWriteln('');

  {DECOMPRESSION Du CONTROL.DAT et Lecture}
   Commande := Copy(Compres(3), Pos(' ', Compres(3)), length(Compres(3)));
   Commande := Commande + ' '+Config.PrescanDir+TempDir+'.QWK '+TempDir+'\ CONTROL.DAT >Nul';

   DosError := DosShell (Reduce(Compres(3), ' ')+' ',Commande,USE_ALL,$ffff,false);
   If DosError <> 0 Then Begin;
                          Writeln;
                          Writeln('Error During De'+Compres(2)+'''ing... DOS ErrorLevel ', DosError);
                          EffaceSecour;
                          Exit;
                         End;
   Assign(F, TempDir+'\CONTROL.DAT');
   {$I-} Reset(F); {$I+}
   If Ioresult <> 0 Then Begin;
                          EffaceSecour;
                          Exit;
                         End;
   For J := 1 To 10 Do ReadLn(F, Commande); TotalMail := StrToInt(Commande);
   Close(F);

  {DECOMPRESSION Du CONTROL.DAT et Lecture}
   Commande := Copy(Compres(3), Pos(' ', Compres(3)), length(Compres(3)));
   Commande := Commande + ' '+Config.PrescanDir+TempDir+'.QWK '+TempDir+'\ PERSONAL.NDX >Nul';
   DosError := DosShell (Reduce(Compres(3), ' ')+' ',Commande,USE_ALL,$ffff,false);
   If DosError <> 0 Then Begin;
                          Writeln;
                          Writeln('Error During De'+Compres(2)+'''ing... DOS ErrorLevel ', DosError);
                          EffaceSecour;
                          Exit;
                         End;
   Assign(Fichier, Tempdir+'\PERSONAL.NDX');
   {$I-} Reset(Fichier); {$I+}
   If Ioresult = 0 Then
    Begin;
     TotalYour := FileSize(Fichier) Div 5;
     Close(Fichier);
    End;

  {$IFDEF ENGLISH}
   RmWriteln(' Number Of Message To Download : '+ IntToStr(TotalMail));
   RmWriteln(' Number Of Message To You      : '+ IntTOStr(TotalYour));
   RmWriteln('');
   RmWrite('Download Packet ? (Y/n/g) : ');
  {$ELSE}
   RmWriteln(' Nombre De Messages A Downloader : '+ IntToStr(TotalMail));
   RmWriteln(' Nombre De Messages Pour Vous    : '+ IntTOStr(TotalYour));
   RmWriteln('');
   RmWrite('Downloader Le Paquet ? (O/n/g) : ');
  {$ENDIF}

   Repeat
    C := Upcase(RmReadKey);
   Until C in ['N', 'Y', 'O','G', #13, #27];
   If C = #13 Then {$IFDEF ENGLISH}
                    C := 'Y';
                   {$ELSE}
                    C := 'O';
                   {$ENDIF}
   If C = #27 Then C := 'N';
   RmWriteln(C);

   Case C Of
    'N' : ;


    'G',
    'Y',
    'O' : Begin;
           DownGood := False;

           RmWriteln('');
          {$IFDEF ENGLISH}
           RmWriteln('ţ Copiing '+Config.BBSID+'.QWK For Transfer...');
          {$ELSE}
           RmWriteln('ţ Copie De '+Config.BBSID+'.QWK Pour Le Transfert...');
          {$ENDIF}
           FCopy(Config.PrescanDir+TempDir+'.QWK',TempDir+'\'+Config.BBSID+'.QWK');

        If Online Then
         Begin;
            RmWriteln('');
          {$IFDEF ENGLISH}
            RmWriteln('ţ Sending Packet '+Config.BBSID+'.QWK With '+Protoc(2));
          {$ELSE}
            RmWriteln('ţ Envoie Du Paquet '+Config.BBSID+'.QWK Avec '+Protoc(2));
          {$ENDIF}
          ClrScr;
          Commande := Copy(Protoc(3), Pos(' ', Protoc(3)), Length(Protoc(3)));
          Commande := Commande + ' '+TempDir+'\'+Config.BBSID+'.QWK';
          LastMinKey := 0;
          DosError := DosShell (Copy(Protoc(3), 1, Pos(' ', Protoc(3))-1),
                        Commande,
                        USE_ALL,
                        $ffff,
                        false);
          LastMinKey := 0;
          If DosError = 0 Then
           Begin;
            RmWriteln('');
          {$IFDEF ENGLISH}
            RmWriteln('ţ Successfull Transfering '+Config.BBSID+'.QWK !');
          {$ELSE}
            RmWriteln('ţ Transfert '+Config.BBSID+'.QWK R‚ussi !');
          {$ENDIF}
            SuccessTransfert;
            DownGood := True;
           End
          Else
           Begin;
            RmWriteln('');
          {$IFDEF ENGLISH}
            RmWriteln('ţ Problem During Transfer !!!:-((((');
          {$ELSE}
            RmWriteln('ţ ProblŠme Durant Le Transfert !!! :-((((');
          {$ENDIF}
            ProblemTransfert;
            DownGood := False;
           End;
         End
        Else DownGood := Moving(Auto, Prescan);

        If DownGood Then
         Begin;
          User.LastQWKDate := Date(0);
          User.LastQWKTime := Time;
          User.NbMessDown  := User.NbMessDown + ToTalMail;
          Inc(User.NbDownPacket);
         {On Efface Le PRESCAN}
          Assign(F, Config.PrescanDir+TempDir+'.QWK');
          Reset(F);
          Close(F);
          Erase(F);
         {On Efface Le BBSID.QWK}
          Assign(F, TempDir+'\'+OLDBBSID+'.QWK');
          Reset(F);
          Close(F);
          Erase(F);
         End;

        If C = 'G' Then
         Begin;
          RmWriteln('');
         {$IFDEF ENGLISH}
          RmWriteln('ţ Auto Hangup');
         {$ELSE}
          RmWriteln('ţ D‚connection Automatique');
         {$ENDIF}
          Delay(500);
          RmHangup;
          Halt(0);
         End;

         If DownGood = True  Then Delay(1500);
         If DownGood = False Then Delay(500);

       End;
    End;
   Exit;
  End;


  If Prescan Then Config.BBSID := TempDir;
  If Prescan Then Config.LocalQWK := Config.PrescanDir;

  If Prescan Then
  If FileExists(Config.PrescanDir+Config.BBSID+'.QWK') Then
  If User.RepeatScan Then
   Begin;
    RmWriteln('ţ D‚compression De L''Ancien Prescan...');
    Commande := Copy(Compres(3), Pos(' ', Compres(3)), length(Compres(3)));
    Commande := Commande + ' '+Config.PrescanDir+Config.BBSID+'.QWK '+TempDir+'\ >Nul';

    DosError := DosShell (Reduce(Compres(3), ' ')+' ',Commande,USE_ALL,$ffff,false);

    If DosError <> 0 Then Begin;
                           Writeln;
                           Writeln('Error During De'+Compres(2)+'''ing... DOS ErrorLevel ', DosError);
                           EffaceSecour;
                           Exit;
                          End;

    Assign(F, TempDir+'\CONTROL.DAT');
    {$I-} Reset(F); {$I+}
    If Ioresult <> 0 Then Begin;
                           EffaceSecour;
                           Exit;
                          End;

    For J := 1 To 09 Do ReadLn(F);
    ReadLn(F, Commande); TotalMail := StrToInt(Commande);
    Close(F);

    Assign(Fichier, Tempdir+'\PERSONAL.NDX');
    {$I-} Reset(Fichier); {$I+}
    If Ioresult = 0 Then
     Begin;
      TotalYour := FileSize(Fichier) Div 5;
      GetFtime(Fichier, J);
      Close(Fichier);
     End;
    UnpackTime(J, FTime);
   {$IFDEF ENGLISH}
    Writeln('ţ Last Prescan Processed : '  ,Ftime.Month,'/',Ftime.Day,'/',Ftime.Year,'-',Ftime.Hour,':',Ftime.Min);
   {$ELSE}
    Writeln('ţ Dernier Prescan Effectu‚ : ',Ftime.Day,'/',Ftime.Month,'/',Ftime.Year,'-',Ftime.Hour,':',Ftime.Min);
   {$ENDIF}
   End
  Else
   Begin;
   {$IFDEF ENGLISH}
    RmWriteln('ţ Erasing Old Prescan...');
   {$ELSE}
    RmWriteln('ţ Effacement De L''Ancien Prescan...');
   {$ENDIF}
    Assign(F, Config.PrescanDir+Config.BBSID+'.QWK');
    Reset(F);
    Close(F);
    Erase(F);
   End;

(* Creation MESSAGE.DAT : Entete *)
  Assign(Message, Tempdir+'\MESSAGES.DAT');
  {$I-} Reset(Message); {$I+}
  If Ioresult <> 0 Then
   Begin;
    Rewrite(Message);
    For J := 1 To 128 Do Buf[J] := MessageHeader[J];
    BlockWrite(Message, Buf, 1);
   End
  Else Seek(Message, FileSize(Message));

(* Creation PERSONAL.IDX : Vide *)

  Assign(PERSO, Tempdir+'\PERSONAL.NDX');
  {$I-} Reset(PERSO); {$I+}
  If Ioresult <> 0 Then Rewrite(PERSO)
                   Else
  If Not Prescan   Then Rewrite(PERSO)
                   Else Append(PERSO);


(* Ouverture du SFMCONF.DAT *)
 Assign(MsgS, Config.SFDir+'SFMCONF.DAT');
 {$I-} Reset(MsgS); {$I+}
 If Ioresult <> 0 Then Exit;

{$IFDEF ENGLISH}
If ( (Auto = True) And (Prescan = False) ) Then RmWriteln('ţ Automatic Scan For '+User.Name);
If Prescan Then RmWriteln('ţ Automatic Prescan For '+User.Name);
RmWriteln('ţ Last QWK Download : '+User.LastQWKDate+' At '+User.LastQWKTime);
RmWriteln('ţ <Space> To Abort !');
RmWriteln('ÉÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍ»');
RmWriteln('ş  BSF-Mail OffLine and Mail Door For Spitfire 3.5     - DOWNLOAD -      ş');
RmWriteln('ÇÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄ¶');
RmWriteln('ş                                   Highest    Last      Number Of  To   ş');
RmWriteln('ş     Conference       Status       Message    Read      Messages   You  ş');
RmWriteln('ČÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍĽ');
RmWriteln('');
{$ELSE}
If ( (Auto = True) And (Prescan = False) ) Then RmWriteln('ţ Scanne Automatique Pour '+User.Name);
If Prescan Then RmWriteln('ţ Prescan Automatique Pour '+User.Name);
RmWriteln('ţ Dernier QWK Download‚ : '+User.LastQWKDate+' A '+User.LastQWKTime);
RmWriteln('ţ <Espace> Pour Stopper !');
RmWriteln('ÉÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍ»');
RmWriteln('ş  BSF-Mail OffLine Et Mail Door Pour Spitfire 3.5     - DOWNLOAD -      ş');
RmWriteln('ÇÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄÄ¶');
RmWriteln('ş                                    Haut     Dernier    Nombre De  Pour ş');
RmWriteln('ş     Conf‚rence       Status       Message   Msg. Lu    Messages   Vous ş');
RmWriteln('ČÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍÍĽ');
RmWriteln('');
{$ENDIF}

(* On Scanne Les Conf‚rences *)

Repeat

{ Lecture Des Donnes Dans SFMCONF.DAT }
 Seek(MsgS, Conf);
 Read(MsgS, Msg);
 Msg.MDesc := Msg.MDesc;

{ Pour Les Confs Selectionnees }
 If ( (SecLevel >= Msg.Msec) And (User.Conf.Attribut[Conf] In [1,2,3,4,101]) ) Then
  Begin;

{ Creation du Fichier Conf+1.NDX }
  Assign(NDXF, TempDir+'\'+NomIDX(Conf)+'.NDX');
  {$I-} Reset(NDXF); {$I+}
  If Ioresult <> 0 Then Rewrite(NDXF)
                   Else Append(NDXF);

{ Remise A Zero De Variables }
  NombreMail  := 0;
  ToYou       := 0;

{ Ouverture du fichier SFMSG[x].IDX Et Prend La Valeur La Plus Haute}
 Higher := LectureIDX;
{ Ouverture/Fermeture du fichier SFMSG[x].LMR }
 LastRead := LMR(0,Conf,0);

{ Si LastRead > Higher Alors LastRead = Higher Et On Enregistre }
 If LastRead > Higher Then
  Begin;
   LMR(1, Conf, Higher);
   Lastread := Higher;
  End;

{ Affichage }
 If Conf <= 8                 Then RmWrite('   '+IntToStr(Conf+1)+' '+Msg.MDesc+Copy(Blanc,1,18-Length(Msg.MDesc))+' '
                               +Flags(User.Conf.Attribut[Conf])+'   '+Copy(Blanc,1,10-Length(IntToStr(Higher)))
                               +IntToStr(Higher)+Copy(Blanc,1,9-Length(IntToStr(LastRead)))+IntToStr(LastRead)+'     ');
 If ((Conf>8) And (Conf<=98)) Then RmWrite('  '+IntToStr(Conf+1)+' '+Msg.MDesc+Copy(Blanc,1,18-Length(Msg.MDesc))+' '
                               +Flags(User.Conf.Attribut[Conf])+'   '+Copy(Blanc,1,10-Length(IntToStr(Higher)))
                               +IntToStr(Higher)+Copy(Blanc,1,9-Length(IntToStr(LastRead)))+IntToStr(LastRead)+'     ');
 If Conf > 98                 Then RmWrite(' '+IntToStr(Conf+1)+' '+Msg.MDesc+Copy(Blanc,1,18-Length(Msg.MDesc))+' '
                               +Flags(User.Conf.Attribut[Conf])+'   '+Copy(Blanc,1,10-Length(IntToStr(Higher)))
                               +IntToStr(Higher)+Copy(Blanc,1,9-Length(IntToStr(LastRead)))+IntToStr(LastRead)+'     ');

{ Si Message, On Commence !!! }
 If ( (Higher > LastRead) And (Higher > 0) ) Then
  Begin;

  Assign(PTR, Config.MsgDir+SFMSG(Conf)+'.PTR');
  Reset(PTR);
  Assign(DataM, Config.MsgDir+SFMSG(Conf)+'.DAT');
  Reset(DataM);

{ Reset Varible Position Message }
  Position := 0;

{ PTR > 0 Alors Message Et On Commence }
 If FileSize(PTR) > 0 Then
 Repeat

{ Au Cas Ou }
 If IoResult <> 0 Then;

 Seek(PTR, Position);
 Read(PTR, PointPTR);

 PointPTR.ToWho := RTrim(PointPTR.ToWho, ' ');

{** STATUS USER *** PAS PERSO **}
 If User.NetStatus = False Then
  If User.Conf.Attribut[Conf] < 100 Then
   If SecLevel >= Msg.Msec Then
    If PointPTR.MsgNumber > LastRead Then
     If PointPTR.Deleted = False Then
      If Personnel = False Then
      Begin;
       Entete(Conf, TotalMail, False);
       Choix := 0;
        If PointPTR.ToWho = UserName Then Inc(Toyou);
   {ALL}
       If User.Conf.Attribut[Conf] = 1 Then
        Begin;
         If PointPTR.Private = False Then Choix := 1;
         If PointPTR.Private = True  Then
          Begin;
           If PointPTR.ToWho = UserName Then Choix := 1 Else Choix := 0;
           If SecLevel >= Config.SysOpLevel Then Choix := 1;
          End;
        End;
   { 'ALL' & Yours }
        If User.Conf.Attribut[Conf] = 2 Then
         If ((MAJ(PointPTR.ToWho)='ALL') Or (MAJ(PointPTR.ToWho)=MAJ(UserName)))
          Then Choix:= 1;
   { Perso }
        If User.Conf.Attribut[Conf] = 3 Then
         If PointPTR.ToWho = UserName Then Choix := 1;
   { Si Retour }
        If PointPTR.FromWho = UserName Then Choix := 0;
   { En Fonction Du Choix }
        Case Choix Of
         0 :;
         1 : Begin;
              EcritureMessage(Conf); { Ecriture Du Message }
              Inc(NombreMail);
          End;
        End;
      End;

{** STATUS USER *** PERSO **}
 If User.NetStatus = False Then
  If User.Conf.Attribut[Conf] < 100 Then
   If SecLevel >= Msg.Msec Then
    If PointPTR.MsgNumber > LastRead Then
     If PointPTR.Deleted = False Then
      If Personnel = True Then
      Begin;
       Entete(Conf, TotalMail, False);
       Choix := 0;
       If User.Conf.Attribut[Conf] In [1,2,3,4] Then
         If PointPTR.ToWho = UserName Then Begin;
                                            Choix := 1;
                                            Inc(ToYou);
                                           End
         Else Choix := 0;
   { En Fonction Du Choix }
        Case Choix Of
         0 :;
         1 : Begin;
              EcritureMessage(Conf);
              Inc(NombreMail);
             End;
        End;
      End;

{*** STATUS NET ***}
  If User.NetStatus = True Then
   If PointPTR.MsgNumber > LastRead Then
    If PointPTR.Deleted = False Then
     If User.Conf.Attribut[Conf] In [101,1] Then
      Begin;
       Entete(Conf, TotalMail, True);

       Choix := 1;

       If PointPTR.ToWho = UserName Then Inc(Toyou);

       NetId := Rep(' ',Length(UserName));
       For I := 0 To Length(UserName) Do NetId[I+1] := PointPTR.NetRoute[I];
       If Username = NetId Then Choix := 0;

       If PointPTR.FromWho = UserName Then Choix := 0;

       Case Choix Of
        0 :;
        1 : Begin;
             EcritureMessage(Conf);
             Inc(NombreMail);
            End;
       End;
     End;


 Inc(Position);

 If RmKeyPressed Then If RmReadKey = #32 Then Stop := True;
 PurgeInBuffer;

 Until ( (Position >= FileSize(PTR))
       Or ((NombreMail >= User.NbMailConf) And (User.NbMailConf > 0))
       Or ((NombreMail+TotalMail >= User.NbMailTTle) And (User.NbMailTtle >0))
       Or (Stop));

 Close(PTR);
 Close(DataM);

 End
 Else PointPTR.MsgNumber := -1;

 TotalYour := TotalYour  + ToYou;
 ToTalMail := TotalMail  + NombreMail;

 RmWriteln(Copy('     ',1,6-Length(IntToStr(NombreMail)))+IntToStr(NombreMail)+'  '
          +Copy('     ',1,6-Length(IntToStr(ToYou)))+InttoStr(ToYou));


 SavePoint[Conf] := PointPTR.MsgNumber;


Close(NDXF);

 If FileExists(TempDir+'\'+NomIDX(Conf)+'.NDX') Then
  Begin;
   Assign(Fichier, TempDir+'\'+NomIDX(Conf)+'.NDX');
   Reset(Fichier);
   If FileSize(Fichier) = 0 Then Begin;
                                  Close(Fichier);
                                  Erase(Fichier);
                                 End
                            Else Close(Fichier);
  End;

 End
Else
 Begin;
  If RmKeyPressed Then If RmReadKey = #32 Then Stop := True;
  PurgeInBuffer;
 End;

 Inc(Conf);

Until ( (Conf >= FileSize(MsgS))
      Or ( (TotalMail >= User.NbMailTTle) And (User.NbMailTTle > 0))
      Or (Stop));           

 Close(Message);
 Close(PERSO);

 RmWriteln('');

 If Stop Then
 {$IFDEF ENGLISH}
  RmWriteln(' *** ABORT BY USER ***');
 {$ELSE}
  RmWriteln(' *** STOPPE PAR L''UTILISATEUR ***');
 {$ENDIF}

 RmWriteln('');

 If User.NbMailTTle > 0 Then If TotalMail >= User.NbMailTTle
  Then
  {$IFDEF ENGLISH}
   RmWriteln('Maximum Messages Reached');
  {$ELSE}
   RmWriteln('Maximum De Messages Atteint');
  {$ENDIF}

 C := 'N';

 RmWriteln('');
{$IFDEF ENGLISH}
 RmWriteln(' Number Of Message To Download : '+ IntToStr(TotalMail));
 RmWriteln(' Number Of Message To You      : '+ IntTOStr(TotalYour));
{$ELSE}
 RmWriteln(' Nombre De Messages A Downloader : '+ IntToStr(TotalMail));
 RmWriteln(' Nombre De Messages Pour Vous    : '+ IntTOStr(TotalYour));
{$ENDIF}

 ScanMail(ToTalMail);

 J := 0;
 J := ToTalMail;

 If User.Bulletin = True Then
  Begin;
   Nombre := 0;
  {$IFDEF ENGLISH}
   RmWrite(' Number Of Bulletins           : ');
  {$ELSE}
   RmWrite(' Nombre De Bulletins             : ');
  {$ENDIF}
   Nombre := BULLETIN(Config.DisplayDir, User.LastQWKDate, TempDir);
   RmWriteln(IntToStr(Nombre));
   ScanBulletins(Nombre);
   J := J + Nombre;
  End;

 If User.NewFiles = True Then
  Begin;
   Nombre := 0;
  {$IFDEF ENGLISH}
   RmWrite(' Number Of New Files           : ');
  {$ELSE}
   RmWrite(' Nombre De Nouveaux Fichiers     : ');
  {$ENDIF}
   Nombre := NewsFiles(Config.SFDIR, SecLevel, User.LastQWKDate, TempDir);
   RmWriteln(IntToStr(Nombre));
   ScanFiles(Nombre);
   J := J + Nombre;
  End;

 If User.News      = True Then ScanNews;
 If User.Welcome   = True Then Welcome(CONFIG.WELCOMEDir, TempDir);
 If User.News      = True Then News(Config.NewsDir, TempDir);
 If User.GoodBye   = True Then Goodbye(Config.GoodbyeDir, TempDir);


 RmWriteln('');
 If J > 0 Then
{$IFDEF ENGLISH}
 RmWrite('Download Packet ? (Y/N/G) : ');
{$ELSE}
 RmWrite('Downloader Le Paquet ? (Y/N/G) : ');
{$ENDIF}

 If ( (J = 0) ) Then
  Begin;
   RmWriteln('');
  {$IFDEF ENGLISH}
   RmWriteln('ţ Nothing To Download');
  {$ELSE}
   RmWriteln('ţ Rien A Downloader');
  {$ENDIF}
  End
 Else
  If Auto = False Then
   Begin;
    Repeat
     C := Upcase(RmReadKey);
    Until C in ['N','Y','G',#13];
    If C = #13 Then C := 'Y';
    RmWriteln(Upcase(C));
   End
  Else
   Begin;
   C := 'Y';
   RmWriteln(Upcase(C));
  End;

 Case C of
   'Y','G'  : Begin;
            RmWriteln('');
          If Not Prescan Then
           {$IFDEF ENGLISH}
            RmWriteln('ţ Preparing '+Config.BBSID+'.QWK')
           {$ELSE}
            RmWriteln('ţ Pr‚paration De '+Config.BBSID+'.QWK')
           {$ENDIF}
          Else
           {$IFDEF ENGLISH}
            RmWriteln('ţ Preparing '+OldBBSID+'.QWK For '+User.Name);
           {$ELSE}
            RmWriteln('ţ Pr‚paration De '+OldBBSID+'.QWK Pour '+User.Name);
           {$ENDIF}

          CONTROLDAT(TotalMail, Prescan);
          BBSIDPNT(Prescan);
          DOORID;

          If User.NetStatus = True Then NETFLAG(Config.SFdir);

 LastMinKey := 0;
 RmWriteln('');
 If Not Prescan Then
{$IFDEF ENGLISH}
 RmWriteln('ţ Compacting Packet '+Config.BBSID+'.QWK With '+Compres(2))
{$ELSE}
 RmWriteln('ţ Compression Du Paquet '+Config.BBSID+'.QWK Avec '+Compres(2))
{$ENDIF}
 Else
{$IFDEF ENGLISH}
 RmWriteln('ţ Compacting Packet '+OldBBSID+'.QWK With '+Compres(2));
{$ELSE}
 RmWriteln('ţ Compression Du Paquet '+OldBBSID+'.QWK Avec '+Compres(2));
{$ENDIF}


 Commande := Copy(Compres(4), Pos(' ', Compres(4)), length(Compres(4)));
 Commande := Commande + ' '+TempDir+'\'+Config.BBSID+'.QWK '+TempDir+'\*.* >Nul';

 DosError := DosShell (Reduce(Compres(4), ' ')+' ', Commande, USE_ALL, $ffff, false);

 If DosError <> 0 Then Begin;
                        Writeln('Error During '+Compres(2)+'''ing... DOS ErrorLevel ', DosError);
                        EffaceSecour;
                        Delay(3000);
                        exit;
                       End;

 If Not Online Then DownGood := Moving(Auto, Prescan);

 If Online Then Begin;

  RmWriteln('');
 {$IFDEF ENGLISH}
  RmWriteln('ţ Sending Packet '+Config.BBSID+'.QWK With '+Protoc(2));
 {$ELSE}
  RmWriteln('ţ Envoie Du Paquet '+Config.BBSID+'.QWK Avec '+Protoc(2));
 {$ENDIF}

  ClrScr;

  Commande := Copy(Protoc(3), Pos(' ', Protoc(3)), Length(Protoc(3)));
  Commande := Commande + ' '+TempDir+'\'+Config.BBSID+'.QWK';
  LastMinKey := 0;
  DosError := DosShell (Copy(Protoc(3), 1, Pos(' ', Protoc(3))-1),
                        Commande,
                        USE_ALL,
                        $ffff,
                        false);
  LastMinKey := 0;
  If DosError = 0 Then
   Begin;
                        RmWriteln('');
                       {$IFDEF ENGLISH}
                        RmWriteln('ţ Successfull Transfering '+Config.BBSID+'.QWK !');
                       {$ELSE}
                        RmWriteln('ţ Transfert '+Config.BBSID+'.QWK R‚ussi !');
                       {$ENDIF}
                        SuccessTransfert;
                        DownGood := True;
                        User.LastQWKDate := Date(0);
                        User.LastQWKTime := Time;
                        User.NbMessDown := User.NbMessDown + ToTalMail;
                        Inc(User.NbDownPacket);
                       End
                  Else Begin;
                       RmWriteln('');
                       {$IFDEF ENGLISH}
                        RmWriteln('ţ Problem During Transfer !!!:-((((');
                       {$ELSE}
                        RmWriteln('ţ ProblŠme Durant Le Transfert !!! :-((((');
                       {$ENDIF}
                       ProblemTransfert;
                       DownGood := False;
                      End;

  End;
  End;

 'N' : DownGood := False;

  End;

  RmWriteln('');

  If DownGood = True Then
   Begin;
    If ToTalMail > 0 Then
     Begin;
     {$IFDEF ENGLISH}
      RmWriteln('ţ Updated Message Pointers ');
     {$ELSE}
      RmWriteln('ţ Mise A Jour Des Pointeurs');
     {$ENDIF}
      UpdatedPoint;
     End;
   End
  Else
  {$IFDEF ENGLISH}
   RmWriteln('ţ Pointers Not Updated');
  {$ELSE}
   RmWriteln('ţ Pointeurs Non Chang‚');
  {$ENDIF}

  Close(MsgS);
  EffaceSecour;

  If DownGood = True  Then Delay(1500);
  If DownGood = False Then Delay(500);

  If C = 'G' Then
   Begin;
    RmWriteln('');
   {$IFDEF ENGLISH}
    RmWriteln('ţ Auto Hangup');
   {$ELSE}
    RmWriteln('ţ D‚connection Automatique');
   {$ENDIF}
    Delay(500);
    RmHangup;
    Halt(0);
   End;

 End;


End.

